# Betfair API credentials
# Get your App Key at: https://developer.betfair.com -> My Account -> API -> Create App Key
# Use a "Delay" key for testing (60s delay, free) or "Live" key for real-time arb (required for live use)
BETFAIR_USERNAME=your_betfair_email@example.com
BETFAIR_PASSWORD=your_betfair_password
BETFAIR_APP_KEY=your_app_key_here
